# ─────────────────────────────────────────────────────────────────────────────
# HR205 LLC — Environment Variables
# Copy this file to .env.local and fill in values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (public keys — safe to expose to browser)
VITE_SUPABASE_URL=https://rdqoibgxiuaenneyqfxn.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Cloudinary (public — safe to expose)
VITE_CLOUDINARY_CLOUD_NAME=hr205
VITE_CLOUDINARY_UPLOAD_PRESET=hr205_team_uploads

# ─── Email routing (server-side only — use in Supabase Edge Functions) ────────
# Primary operational mailboxes @ hr205.org
ADMIN_EMAIL=admin@hr205.org        # Manager portal auth + admin notifications
SUPPORT_EMAIL=support@hr205.org    # Contact form submissions + customer support
DISPATCH_EMAIL=dispatch@hr205.org  # Rep dispatch, hiring inquiries, operations
INFO_EMAIL=info@hr205.org          # General info, public-facing

# Representative mailboxes
REP1_EMAIL=rep1@hr205.org
REP2_EMAIL=rep2@hr205.org
REP3_EMAIL=rep3@hr205.org

# ─── SMTP (for outbound email via Supabase Edge Functions) ───────────────────
# Recommended: Resend (resend.com) — simple API, works with hr205.org domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# Alternative: Zoho SMTP (if using Zoho Mail for hr205.org)
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# SMTP_USER=admin@hr205.org
# SMTP_PASS=your_password

# Alternative: Google Workspace SMTP (if using Google for hr205.org)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=admin@hr205.org
# SMTP_PASS=your_app_password
